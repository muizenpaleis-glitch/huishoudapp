// Huishoud-app database schema
// Covers: Huishouden (household members), Contracten, Onderhoud, Financien

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────── Huishouden ─────────────────────────

model HouseholdMember {
  id        String   @id @default(cuid())
  naam      String
  email     String?
  kleur     String
  createdAt DateTime @default(now())

  contracten           Contract[]
  onderhoudSubtaken    Subtaak[]
  onderhoudToegewezen  OnderhoudItem[] @relation("Toegewezen")
  pushSubscriptions    PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  memberId  String?
  member    HouseholdMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model AppSettings {
  id                Int     @id @default(1)
  contractDrempel   Int     @default(60)
  contractMail      Boolean @default(true)
  contractPush      Boolean @default(false)
  onderhoudDrempel  Int     @default(14)
}

// Dedupe log so the reminder check doesn't re-send the same push every run.
model NotificationLog {
  key    String   @id // e.g. "contract:<id>" or "onderhoud:<id>"
  sentAt DateTime @default(now())
}

// ───────────────────────── Contracten ─────────────────────────

enum ContractCategorie {
  Energie
  Verzekering
  Abonnement
  Overig
}

enum ContractStatus {
  Actief
  Opgezegd
  Verlopen
}

enum OpzegType {
  periode
  datum
}

model Contract {
  id            String            @id @default(cuid())
  naam          String
  leverancier   String
  categorie     ContractCategorie
  startdatum    DateTime?
  einddatum     DateTime
  opzegType     OpzegType         @default(periode)
  opzegMaanden  Int               @default(1)
  opzegDatum    DateTime?
  autoRenewal   Boolean           @default(true)
  status        ContractStatus    @default(Actief)
  docNaam       String?
  docUrl        String?
  notitie       String?
  beheerderId   String?
  beheerder     HouseholdMember?  @relation(fields: [beheerderId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// ───────────────────────── Onderhoud ─────────────────────────

enum OnderhoudType {
  periodiek
  taak
}

enum OnderhoudCategorie {
  Huis
  Apparaten
  Auto
  Tuin
  Overig
}

enum OnderhoudPrioriteit {
  Hoog
  Gemiddeld
  Laag
}

enum TaakStatus {
  Te_doen   @map("Te doen")
  Mee_bezig @map("Mee bezig")
  Klaar
}

model OnderhoudItem {
  id               String               @id @default(cuid())
  type             OnderhoudType
  naam             String
  categorie        OnderhoudCategorie
  prio             OnderhoudPrioriteit
  doc              String?
  docUrl           String?
  notitie          String?
  notitieKort      String?

  // periodiek-specific
  intervalMaanden  Int?
  intervalLabel    String?
  volgende         DateTime?

  // taak-specific
  status           TaakStatus?
  streefdatum      DateTime?
  toegewezenId     String?
  toegewezen       HouseholdMember?     @relation("Toegewezen", fields: [toegewezenId], references: [id], onDelete: SetNull)

  logs             OnderhoudLog[]
  subtaken         Subtaak[]
  vrijeInhoud      VrijeInhoudBlok[]

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model OnderhoudLog {
  id       String        @id @default(cuid())
  itemId   String
  item     OnderhoudItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  datum    DateTime
  notitie  String?
  doc      String?
}

model Subtaak {
  id            String        @id @default(cuid())
  itemId        String
  item          OnderhoudItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tekst         String
  klaar         Boolean       @default(false)
  toegewezenId  String?
  toegewezen    HouseholdMember? @relation(fields: [toegewezenId], references: [id], onDelete: SetNull)
  volgorde      Int           @default(0)
}

enum VrijeInhoudKind {
  tekst
  foto
}

model VrijeInhoudBlok {
  id         String          @id @default(cuid())
  itemId     String
  item       OnderhoudItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  kind       VrijeInhoudKind
  volgorde   Int             @default(0)
  tekst      String?
  imageUrl   String?
  label      String?
}

// ───────────────────────── Financien ─────────────────────────
// Raw model: the app stores raw bank transactions + manual overrides +
// settings + editable projects/yearly items, and computes everything live
// (classification → aggregation → buffer → MJP projection) with the ported
// engine in src/lib/finance/. This mirrors the original finance_cockpit.html
// exactly, so every displayed figure is derived (never baked in).

model FinanceSettings {
  id                         Int      @id @default(1)
  startNetWorth              Decimal  @db.Decimal(12, 2)
  returnRate                 Decimal  @db.Decimal(6, 3)
  horizon                    Int
  savingsGrowth              Decimal  @db.Decimal(6, 3)
  monthlyBudget              Decimal  @db.Decimal(12, 2)
  monthlyIncome              Decimal  @db.Decimal(12, 2)
  threshold                  Decimal  @db.Decimal(12, 2)
  savingsAccounts            String[]
  investmentAccounts         String[]
  savingsIncidentalThreshold Decimal  @db.Decimal(12, 2)
  categoryBudgets            Json // Record<bankCategory, monthlyBudget>
  personalSavings            Decimal  @db.Decimal(12, 2)
  investmentValue            Decimal  @db.Decimal(12, 2)
}

model FinanceTx {
  id            String  @id // composite "dd-mm-yyyy|seq|amount" from the ASN export
  date          String // YYYY-MM-DD (string slicing drives the engine)
  iban          String
  naam          String
  balanceBefore Decimal @db.Decimal(12, 2)
  amount        Decimal @db.Decimal(12, 2)
  code          String
  seq           String
  descr         String
  bankCat       String
}

model FinanceOverride {
  txId          String   @id
  cls           String?
  project       String?
  bankCat       String?
  notInvestment Boolean?
  savingsInc    Boolean?
}

model FinanceProject {
  id       String  @id @default(cuid())
  naam     String
  budget   Decimal @db.Decimal(12, 2)
  jaar     Int
  done     Boolean @default(false)
  volgorde Int     @default(0)
}

model FinanceYearly {
  id       String  @id @default(cuid())
  naam     String
  budget   Decimal @db.Decimal(12, 2)
  volgorde Int     @default(0)
}

// ───────────────────────── Huis (Home Assistant) ─────────────────────────
// Demo data for now — no live Home Assistant connection yet. Structured so a
// later pass can map each row onto a real HA entity_id without a schema
// change (see README).

enum KleurTemp {
  warm
  neutraal
  koel
}

model HuisLamp {
  id         String    @id @default(cuid())
  naam       String
  kamer      String
  aan        Boolean   @default(false)
  helderheid Int       @default(50)
  kleurTemp  KleurTemp @default(neutraal)
  volgorde   Int       @default(0)
}

model HuisCamera {
  id              String    @id @default(cuid())
  naam            String
  laatsteBeweging DateTime?
  volgorde        Int       @default(0)
}

enum LaadpaalStatus {
  vrij
  laden
  gepauzeerd
  klaar
}

model HuisLaadpaal {
  id               Int              @id @default(1)
  status           LaadpaalStatus   @default(vrij)
  huidigVermogenKw Decimal          @db.Decimal(5, 2) @default(0)
  sessies          HuisLaadSessie[]
}

model HuisLaadSessie {
  id          String       @id @default(cuid())
  laadpaalId  Int          @default(1)
  laadpaal    HuisLaadpaal @relation(fields: [laadpaalId], references: [id], onDelete: Cascade)
  datum       DateTime
  duurMinuten Int
  kwh         Decimal      @db.Decimal(5, 2)
}

model HuisAutomatisering {
  id             Int       @id @default(1)
  aan            Boolean   @default(true)
  laatsteActie   String?
  laatsteActieOp DateTime?
}

model HuisEnergieStatus {
  id                        Int     @id @default(1)
  verbruikNuKw              Decimal @db.Decimal(5, 2) @default(0)
  opwekNuKw                 Decimal @db.Decimal(5, 2) @default(0)
  terugleveringNuKw         Decimal @db.Decimal(5, 2) @default(0)
  verbruikVandaagKwh        Decimal @db.Decimal(6, 2) @default(0)
  opwekVandaagKwh           Decimal @db.Decimal(6, 2) @default(0)
  teruggeleverdVandaagKwh   Decimal @db.Decimal(6, 2) @default(0)
  warmtepompVandaagKwh      Decimal @db.Decimal(5, 2) @default(0)
  warmtepompBijgewerkt      DateTime?
}

model HuisEnergieMeting {
  id       String  @id @default(cuid())
  periode  String  // 'dag' | 'week' | 'maand'
  label    String  // '00u', 'Ma', 'Wk 1', ...
  verbruik Decimal @db.Decimal(6, 2)
  opwek    Decimal @db.Decimal(6, 2)
  volgorde Int     @default(0)
}

model HuisFavoriet {
  id       String @id @default(cuid())
  key      String @unique // 'lamp:<id>' | 'laadpaal' | 'automatisering'
  volgorde Int    @default(0)
}
